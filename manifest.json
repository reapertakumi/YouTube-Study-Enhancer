{
  "manifest_version": 3,
  "name": "YouTube Study Enhancer",
  "version": "0.1",
  "description": "Enhances your Study Quality",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}